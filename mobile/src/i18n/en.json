    "cgu": {
      "title": "Terms and Conditions",
      "lastUpdate": "Last updated: June 2026",
      "s1": { "title": "1. Purpose", "body": "CamWallet is a QR-code payment service for the Cameroon market. QR Credit is an internal prepaid balance, separate from a bank account." },
      "s2": { "title": "2. Access conditions", "body": "Access is reserved for individuals residing in Cameroon, of legal age or with parental consent. Registration requires a valid phone number (+237)." },
      "s3": { "title": "3. Use of service", "body": "The service enables P2P transfers, QR payments at partner merchants, top-ups and withdrawals via Orange Money or MTN Mobile Money." },
      "s4": { "title": "4. Security", "body": "You are responsible for keeping your 6-digit PIN confidential. If your phone is lost, contact support immediately to block your account." },
      "s5": { "title": "5. Financial limits", "body": "Per-transaction limit: 500,000 XAF. Daily limits set by partner operators. CamWallet reserves the right to modify these limits." },
      "s6": { "title": "6. Liability", "body": "CamWallet cannot be held liable for service interruptions from third-party operators (Orange Money, MTN MoMo) or force majeure." },
      "s7": { "title": "7. Termination", "body": "You can delete your account from the Profile tab. The remaining balance will be lost if not withdrawn beforehand." },
      "s8": { "title": "8. Contact", "body": "Support: support@camwallet.cm · WhatsApp: +237 600 000 000" }
    },
    "privacyPolicy": {
      "title": "Privacy Policy",
      "lastUpdate": "Last updated: June 2026",
      "s1": { "title": "Data collected", "body": "Full name, phone number, date of birth, city, email address (optional), profile photo, KYC documents (ID front/back + selfie)." },
      "s2": { "title": "Purpose", "body": "Identity verification (KYC), fraud prevention, ANIF/COBAC compliance, payment service provision, transactional notifications." },
      "s3": { "title": "Retention", "body": "Your data is kept for 5 years after account closure, in accordance with Cameroonian legal obligations." },
      "s4": { "title": "Sharing", "body": "We never sell your data. It may be shared with regulatory authorities (ANIF) when legally required." },
      "s5": { "title": "Your rights", "body": "Access, rectification, deletion of your data: send your request to privacy@camwallet.cm. Response time: 30 days." },
      "s6": { "title": "Security", "body": "Data encrypted in transit (TLS 1.3) and at rest. PIN stored as bcrypt hash (cost 12). Short-lived JWT tokens." },
      "s7": { "title": "DPO contact", "body": "Data Protection Officer: dpo@camwallet.cm" }
    }
  },
