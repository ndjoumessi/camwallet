{
  "expo": {
    "name": "CamWallet",
    "slug": "camwallet",
    "version": "2.3.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.camwallet.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "CamWallet a besoin d'accéder à la caméra pour scanner les QR Codes.",
        "NSFaceIDUsageDescription": "CamWallet utilise Face ID pour sécuriser l'accès à votre compte.",
        "NSLocalAuthenticationDescription": "Authentification biométrique pour CamWallet",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.camwallet.app",
      "versionCode": 5,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "CamWallet a besoin d'accéder à la caméra pour scanner les QR Codes."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "CamWallet utilise Face ID pour sécuriser l'accès."
        }
      ],
      "expo-asset",
      "expo-notifications",
      "expo-localization",
      "expo-font",
      "./plugins/withReleaseSigning"
    ],
    "scheme": "camwallet",
    "experiments": {
      "typedRoutes": true
    },
    "owner": "ndjoumessi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a1d68a24-46f1-4fb1-9770-1583ac6f95b4",
      "codeSigningCertificate": "./certs/certificate.pem",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      }
    },
    "extra": {
      "eas": {
        "projectId": "a1d68a24-46f1-4fb1-9770-1583ac6f95b4"
      },
      "router": {}
    }
  }
}
