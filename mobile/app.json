{
  "expo": {
    "name": "CamWallet",
    "slug": "camwallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.camwallet.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "CamWallet a besoin d'accéder à la caméra pour scanner les QR Codes.",
        "NSFaceIDUsageDescription": "CamWallet utilise Face ID pour sécuriser l'accès à votre compte.",
        "NSLocalAuthenticationDescription": "Authentification biométrique pour CamWallet"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.camwallet.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "CamWallet a besoin d'accéder à la caméra pour scanner les QR Codes."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "CamWallet utilise Face ID pour sécuriser l'accès."
        }
      ],
      "expo-asset"
    ],
    "scheme": "camwallet",
    "experiments": {
      "typedRoutes": true
    }
  }
}
