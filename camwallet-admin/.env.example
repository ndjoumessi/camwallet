# Origine de l'API CamWallet (sans le suffixe /api/v1, ajouté automatiquement).
# Par défaut : http://localhost:3000
VITE_API_URL=http://localhost:3000

# Clé Google Maps (carte de répartition géographique de la page Analytique).
# Sans clé, l'admin retombe sur la carte SVG d3-geo (aucune fonctionnalité perdue).
# Créer la clé sur https://console.cloud.google.com (API « Maps JavaScript »).
VITE_GOOGLE_MAPS_API_KEY=
