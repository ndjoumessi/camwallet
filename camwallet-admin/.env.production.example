# Variables d'environnement admin — production (Vercel).
# Origine de l'API CamWallet (sans le suffixe /api/v1).
VITE_API_URL=https://camwallet-production.up.railway.app

# Clé Google Maps (carte géographique de la page Analytique).
# API « Maps JavaScript » + bibliothèque « visualization » (heatmap).
# Restreindre la clé au domaine admin.camwallet.cm en production.
VITE_GOOGLE_MAPS_API_KEY=<cle_google_maps_javascript>
