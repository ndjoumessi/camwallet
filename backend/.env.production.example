# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://api.camwallet.cm

# ─── Base de données (Supabase) ───────────────────────────────────────────────
# URL via pgBouncer (transaction mode) — connexions poolées pour le runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# URL directe — pour Prisma Migrate / Studio (bypass pgBouncer obligatoire)
DIRECT_DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=<jwt_secret_min_64_chars>
JWT_REFRESH_SECRET=<jwt_refresh_secret_min_64_chars>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Pepper PIN (défense en profondeur) ───────────────────────────────────────
# HMAC-SHA256(pin, PIN_PEPPER) appliqué avant bcrypt : un vol de la base seule ne
# permet pas de bruteforcer les PIN sans ce secret (qui ne vit que dans l'env).
# Générer avec : openssl rand -base64 32
# NB : conserver durablement — le changer invalide la connexion de tous les PIN
# existants (aucune migration possible sans l'ancien pepper).
PIN_PEPPER=<pin_pepper_base64_32_bytes>

# ─── SMS OTP (AfricasTalking — couverture Cameroun) ───────────────────────────
# Renseigner dans Railway (Variables). Tant que AT_API_KEY est vide, le backend
# logge les SMS sans les envoyer (dev local).
#   • Sandbox : AT_USERNAME=sandbox + la clé de l'app Sandbox. Le SDK route
#     automatiquement vers l'endpoint sandbox. ⚠️ Aucune livraison réelle :
#     les messages ne sont visibles que dans le simulateur AfricasTalking.
#     AT_SENDER_ID est ignoré (et volontairement omis) en sandbox.
#   • Live : AT_USERNAME=<username live> + clé live. AT_SENDER_ID optionnel
#     (sender ID alphanumérique, doit être enregistré/approuvé par AT).
AT_API_KEY=<cle_api_africastalking>
AT_USERNAME=sandbox
AT_SENDER_ID=CamWallet

# ─── CamPay production (agrégateur Orange Money + MTN MoMo) ──────────────────
CAMPAY_BASE_URL=https://campay.net/api
CAMPAY_USERNAME=<username_campay_production>
CAMPAY_PASSWORD=<password_campay_production>
CAMPAY_APP_TOKEN=<app_token_campay_production>
CAMPAY_WEBHOOK_KEY=<cle_secrete_webhook_campay>

# ─── Orange Money / MTN MoMo (webhooks legacy) ────────────────────────────────
OM_WEBHOOK_SECRET=<secret_signature_orange_money>
MTN_WEBHOOK_SECRET=<secret_signature_mtn_momo>

# ─── Cloudinary (documents KYC) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# ─── Pré-validation KYC par IA (Claude Vision — API Anthropic) ────────────────
# À configurer dans Railway (Variables). Vide = analyse IA désactivée.
ANTHROPIC_API_KEY=<cle_api_anthropic>
# Score IA minimal pour l'auto-approbation KYC (activée via le toggle admin).
KYC_AUTO_APPROVE_THRESHOLD=95

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=<email_admin_production>
# Min 16 chars, majuscule + minuscule + chiffre + symbole
ADMIN_PASSWORD=<mot_de_passe_fort>

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ─── Retraits ─────────────────────────────────────────────────────────────────
WITHDRAWAL_TIMEOUT_MINUTES=10

# ─── Sentry (monitoring erreurs production) ───────────────────────────────────
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project_id>

# ─── Proxy (Railway place un reverse proxy devant l'app) ──────────────────────
TRUST_PROXY=1

# ─── IP Whitelisting admin (IPs séparées par virgules — vide = désactivé) ─────
ADMIN_IP_WHITELIST=

# ─── Alertes email automatiques (AlertEmailService) ───────────────────────────
# Clé Resend (https://resend.com) ; destinataire des alertes opérateurs.
RESEND_API_KEY=<cle_api_resend>
ALERT_EMAIL=<email_destinataire_alertes>
ALERT_EMAIL_FROM=CamWallet Alertes <alertes@camwallet.cm>

# ─── Cache Redis (optionnel — sinon cache en mémoire du process) ──────────────
REDIS_URL=<redis://default:password@host:6379>
