// CamWallet — Schéma Prisma
// PostgreSQL + ACID transactions financières

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl est utilisé uniquement par Prisma Migrate/Studio (pas les requêtes
  // runtime). Requis quand DATABASE_URL pointe vers un pooler (Supabase pgBouncer,
  // Neon serverless) qui ne supporte pas les commandes DDL en transaction mode.
  // En dev local avec PostgreSQL direct, laisser vide ou commenter.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// UTILISATEURS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  phoneCode   String   @default("+237") // Cameroun
  fullName    String?
  email       String?  @unique
  pinHash     String   // PIN 6 chiffres bcrypt
  role        UserRole @default(USER)
  status      UserStatus @default(ACTIVE)
  kycStatus   KycStatus  @default(PENDING)

  // Sécurité
  pinAttempts          Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  tokenVersion         Int       @default(0) // Incrémenté à chaque logout — invalide les refresh tokens émis avant
  previousPinHashes    String[]  @default([]) // Hashes des 3 derniers PIN (réutilisation interdite)
  pendingTotpSecret    String?   // Secret TOTP en attente de vérification (pas encore activé)

  // Notifications push (jeton Expo)
  pushToken       String?

  // Profil
  avatarUrl       String?
  dateOfBirth     DateTime?
  city            String?

  // Admin étendu
  adminRole       String?  // SUPER_ADMIN | ADMIN | COMPLIANCE_OFFICER | SUPPORT_OPERATOR | FINANCE_OFFICER | null
  passwordHash    String?  // Mot de passe admin (login par-utilisateur), bcrypt — null = pas de login direct
  totpSecret      String?
  totpEnabled     Boolean  @default(false)

  // Soft delete
  deletedAt       DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  wallet          Wallet?
  kycDocument     KycDocument?
  sentTransactions     Transaction[] @relation("Sender")
  receivedTransactions Transaction[] @relation("Receiver")
  qrCodes         QrCode[]
  otpCodes        OtpCode[]
  auditLogs       AuditLog[]
  loyaltyPoints   LoyaltyPoints?
  adminNotes      AdminNote[]    @relation("AdminNotes")
  authoredNotes   AdminNote[]    @relation("AdminNoteAuthor")
  disputes        DisputeRequest[] @relation("DisputeRequester")
  supportTickets  SupportTicket[]  @relation("TicketClient")
  assignedTickets SupportTicket[]  @relation("TicketAssignee")
  supportMessages SupportMessage[] @relation("SupportMessageAuthor")

  @@map("users")
}

enum UserRole {
  USER
  MERCHANT
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  DELETED
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  RESUBMIT_REQUIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// PORTEFEUILLE (solde virtuel QR)
// ─────────────────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  // Solde en centimes FCFA (évite les flottants)
  // Ex: 10000 = 100 FCFA
  balance   BigInt   @default(0)
  currency  String   @default("XAF")

  // Limites réglementaires
  dailyLimit   BigInt @default(50000000)  // 500 000 FCFA/jour
  monthlyLimit BigInt @default(500000000) // 5 000 000 FCFA/mois

  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTIONS — table centrale ACID
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id          String            @id @default(uuid())
  reference   String            @unique @default(uuid()) // Référence externe

  type        TransactionType
  status      TransactionStatus @default(PENDING)

  // Montant en centimes FCFA
  amount      BigInt
  fee         BigInt            @default(0)
  currency    String            @default("XAF")

  // Parties
  senderId    String?
  sender      User?             @relation("Sender", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?             @relation("Receiver", fields: [receiverId], references: [id])

  // Métadonnées
  description String?
  qrCodeId    String?
  qrCode      QrCode?           @relation(fields: [qrCodeId], references: [id])

  // Opérateur mobile (recharge/retrait)
  operator        MobileOperator?
  operatorRef     String?           // Référence chez l'opérateur
  operatorStatus  String?

  // Échecs
  failureReason   String?
  retryCount      Int     @default(0)

  // Instantanés de solde de l'émetteur (centimes) — capturés dans la transaction
  // ACID au moment du débit. Null pour les transactions antérieures à la feature.
  senderBalanceBefore BigInt?
  senderBalanceAfter  BigInt?

  // Marquage de résolution des transactions signalées (revue conformité).
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?

  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("transactions")
  // Index composés : l'historique filtre par (senderId OR receiverId) et trie par
  // createdAt DESC. Les index [colonne, createdAt] couvrent chaque branche du OR
  // ET l'ordre, et rendent les index simples [senderId]/[receiverId] redondants.
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum TransactionType {
  P2P        // Envoi entre utilisateurs
  QR_PAYMENT // Paiement via QR Code
  RECHARGE   // Rechargement depuis OM/MoMo
  WITHDRAWAL // Retrait vers OM/MoMo
  REFUND     // Remboursement
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum MobileOperator {
  ORANGE_MONEY
  MTN_MOMO
  CAMPAY
}

// ─────────────────────────────────────────────────────────────────────────────
// QR CODES
// ─────────────────────────────────────────────────────────────────────────────

model QrCode {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  type      QrCodeType @default(STATIC)
  payload   String     // Données encodées dans le QR

  // QR Dynamique uniquement
  amount    BigInt?
  expiresAt DateTime?
  usedAt    DateTime?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  transactions Transaction[]

  @@map("qr_codes")
}

enum QrCodeType {
  STATIC   // QR fixe lié au compte, réutilisable
  DYNAMIC  // QR avec montant spécifique, à usage unique
}

// ─────────────────────────────────────────────────────────────────────────────
// OTP SMS
// ─────────────────────────────────────────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  code      String   // Code 6 chiffres hashé
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)

  createdAt DateTime @default(now())

  @@map("otp_codes")
  @@index([userId, purpose])
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PIN_RESET
  WITHDRAWAL_CONFIRM
}

// ─────────────────────────────────────────────────────────────────────────────
// KYC
// ─────────────────────────────────────────────────────────────────────────────

model KycDocument {
  id         String    @id @default(uuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])

  idFrontUrl String    // URL Cloudinary CNI recto
  idBackUrl  String    // URL Cloudinary CNI verso
  selfieUrl  String    // URL Cloudinary selfie

  status     KycStatus @default(SUBMITTED)
  reviewedBy String?   // Admin user ID
  reviewNote String?
  reviewedAt DateTime?

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("kyc_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// WEBHOOKS OPÉRATEURS
// ─────────────────────────────────────────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(uuid())
  operator    MobileOperator
  eventType   String
  payload     Json
  signature   String?
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?

  createdAt   DateTime @default(now())

  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG — traçabilité réglementaire ANIF
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  action    String   // Ex: "TRANSACTION_CREATED", "PIN_CHANGED"
  resource  String?  // Ex: "Transaction:uuid"
  ipAddress String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PARAMÈTRES SYSTÈME — clés de configuration modifiables par l'admin
// ─────────────────────────────────────────────────────────────────────────────

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// FIDÉLITÉ
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyPoints {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("loyalty_points")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTES ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model AdminNote {
  id        String   @id @default(uuid())
  targetId  String
  target    User     @relation("AdminNotes", fields: [targetId], references: [id])
  authorId  String
  author    User     @relation("AdminNoteAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTESTATIONS
// ─────────────────────────────────────────────────────────────────────────────

model DisputeRequest {
  id            String   @id @default(uuid())
  transactionId String
  requesterId   String
  requester     User     @relation("DisputeRequester", fields: [requesterId], references: [id])
  reason        String
  status        String   @default("OPEN")
  resolution    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dispute_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPORT & TICKETS
// ─────────────────────────────────────────────────────────────────────────────

model SupportTicket {
  id          String          @id @default(uuid())
  reference   String          @unique // TICKET-XXXX
  title       String
  description String

  category    TicketCategory  @default(OTHER)
  priority    TicketPriority  @default(MEDIUM)
  status      TicketStatus    @default(OPEN)

  // Client concerné
  userId      String
  user        User            @relation("TicketClient", fields: [userId], references: [id])

  // Admin qui traite (nullable)
  assignedTo  String?
  assignee    User?           @relation("TicketAssignee", fields: [assignedTo], references: [id])

  messages    SupportMessage[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  resolvedAt  DateTime?

  @@map("support_tickets")
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([userId])
}

model SupportMessage {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation("SupportMessageAuthor", fields: [authorId], references: [id])
  authorRole String        // ADMIN | USER
  content    String
  internal   Boolean       @default(false) // note interne visible admins uniquement
  createdAt  DateTime      @default(now())

  @@map("support_messages")
  @@index([ticketId])
}

enum TicketCategory {
  PAYMENT
  ACCOUNT
  KYC
  TECHNICAL
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
