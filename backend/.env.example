# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Base de données ──────────────────────────────────────────────────────────
# Dev local (docker-compose, port 5433 pour éviter conflit avec PostgreSQL natif)
DATABASE_URL="postgresql://camwallet:password@localhost:5433/camwallet_dev?schema=public"

# Supabase (production) — exemple :
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# Neon (production) — exemple :
# DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.eu-west-2.aws.neon.tech/camwallet?sslmode=require&pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://[user]:[password]@[endpoint].eu-west-2.aws.neon.tech/camwallet?sslmode=require"

# directUrl est utilisé par Prisma Migrate uniquement (DDL via connexion directe,
# pas via le pooler). En dev local sans pooler, mettre la même valeur que DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://camwallet:password@localhost:5433/camwallet_dev?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMS OTP (AfricasTalking — couverture Cameroun) ───────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=CamWallet

# ─── Orange Money Cameroun ────────────────────────────────────────────────────
OM_API_URL=https://api.orange.com/orange-money-webpay/cm/v1
OM_CLIENT_ID=your_orange_money_client_id
OM_CLIENT_SECRET=your_orange_money_client_secret
OM_MERCHANT_KEY=your_merchant_key
OM_WEBHOOK_SECRET=your_webhook_signature_secret

# ─── MTN Mobile Money ─────────────────────────────────────────────────────────
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_COLLECTION_API_KEY=your_mtn_collection_api_key
MTN_COLLECTION_USER_ID=your_mtn_collection_user_id
MTN_DISBURSEMENT_API_KEY=your_mtn_disbursement_api_key
MTN_DISBURSEMENT_USER_ID=your_mtn_disbursement_user_id
MTN_ENVIRONMENT=sandbox
MTN_WEBHOOK_SECRET=your_mtn_webhook_secret

# ─── Stockage fichiers KYC (Cloudinary) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@camwallet.cm
ADMIN_PASSWORD=Admin@2025!

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ─── Retraits ─────────────────────────────────────────────────────────────────
# Délai (minutes) au-delà duquel un retrait resté PENDING est automatiquement
# annulé et remboursé par le balayeur planifié (toutes les 30 s).
WITHDRAWAL_TIMEOUT_MINUTES=10

# ─── Sentry (monitoring) ──────────────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn_here

# ─── Proxy / réseau ───────────────────────────────────────────────────────────
# Activer si l'app est derrière un reverse proxy (Nginx, Caddy, LB cloud).
# Valeurs : vide (désactivé), '1' (un saut de proxy), CIDR (ex: '10.0.0.0/8')
# Ne jamais mettre 'true' en production sur un IP public sans restriction CIDR.
TRUST_PROXY=

# ─── IP Whitelisting admin (optionnel — laisser vide en développement) ────────
# Format : IP1,IP2,IP3 (ex: 192.168.1.1,10.0.0.2)
ADMIN_IP_WHITELIST=
